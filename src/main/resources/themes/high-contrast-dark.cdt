# CADette theme — high-contrast-dark
# Pure black backgrounds, pure-white text. For low-light shops or
# accessibility needs.

name: high-contrast-dark
description: High-contrast dark — pure black backgrounds, pure white text
extends: dark

elements:

  label:
    color: "#ffffff"

  textField:
    color: "#ffffff"
    background: "#000000ff"

  items:
    color: "#ffffff"

  button:
    color: "#ffffff"
    background: "#000000ff"
